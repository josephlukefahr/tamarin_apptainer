Bootstrap: docker
From: debian:13-slim

%post
    apt-get update && apt-get install -y --no-install-recommends\
        texlive-full\
        && rm -rf /var/lib/apt/lists/*

%runscript
    mkdir -p build
    cd ./src\
        && pdflatex --output-directory=../build main\
        && cp main.bib ../build
    cd ../build\
        && makeglossaries main\
        && biber main
    cd ../src\
        && pdflatex --output-directory=../build main
